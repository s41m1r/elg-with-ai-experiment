# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this file to .env and fill in your credentials.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM API Keys ─────────────────────────────────────────────────────────────
# OpenAI (GPT-4o)
OPENAI_API_KEY=sk-...

# Anthropic (Claude Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# Groq (Llama 3 70B — free tier available at https://console.groq.com)
GROQ_API_KEY=gsk_...

# ── PostgreSQL — Full MIMIC-IV OMOP CDM ──────────────────────────────────────
# Required only for Option B (full reproduction with real MIMIC-IV data).
# Requires PhysioNet credentialing: https://physionet.org/content/mimiciv/
PG_HOST=localhost
PG_PORT=5432
PG_DB=mimic
PG_USER=your_username
PG_PASSWORD=your_password
PG_SCHEMA=cdm

# ── Optional settings ────────────────────────────────────────────────────────
# Maximum number of retries for failed LLM API calls (default: 3)
LLM_MAX_RETRIES=3

# Timeout in seconds for LLM API calls (default: 120)
LLM_TIMEOUT=120
